{
  "name": "@knightandwizard/server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:reset": "tsx src/db/reset.ts",
    "lint": "eslint src drizzle.config.ts",
    "test": "pnpm --dir ../.. exec vitest run apps/server/src",
    "typecheck": "tsc -b",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "db:seed": "tsx src/db/seed.ts",
    "knowledge:dry-run": "tsx src/knowledge/dry-run.ts"
  },
  "dependencies": {
    "@knightandwizard/catalogs": "workspace:*",
    "@knightandwizard/rules-core": "workspace:*",
    "@mastra/core": "^1.29.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "js-yaml": "^4.1.1",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
