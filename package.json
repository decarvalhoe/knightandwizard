{
  "name": "knightandwizard-monorepo",
  "version": "0.1.0",
  "description": "Knight & Wizard digital tabletop foundation: canonical rules, catalogs, rules engine, devlab, backend API and RAG-ready knowledge base.",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "devlab:up": "docker compose up -d",
    "devlab:down": "docker compose down",
    "devlab:logs": "docker compose logs -f",
    "devlab:ps": "docker compose ps",
    "devlab:test": "bash scripts/check-devlab.sh",
    "dev:cms": "pnpm --filter @knightandwizard/cms dev",
    "cms:import:catalogs": "tsx tools/import-catalogs.ts",
    "cms:import:catalogs:dry-run": "tsx tools/import-catalogs.ts --dry-run",
    "cms:verify:catalogs": "tsx tools/import-catalogs.ts --verify-only",
    "cms:generate:importmap": "pnpm --filter @knightandwizard/cms generate:importmap",
    "cms:generate:types": "pnpm --filter @knightandwizard/cms generate:types",
    "dev:map": "pnpm --filter knight-and-wizard-interactive-map dev",
    "build:map": "pnpm --filter knight-and-wizard-interactive-map build",
    "yaml2geojson": "python3 apps/interactive-map/tools/yaml_to_geojson.py",
    "validate:geojson": "python3 apps/interactive-map/tools/validate_geojson.py",
    "lint": "eslint .",
    "format": "prettier --write README.md CONTRIBUTING.md AGENTS.md \"docs/plan/*.md\" \"apps/README.md\" \"data/README.md\" \"docs/README.md\" \"docs/product/README.md\" \"packages/**/*.{ts,json}\" \"apps/server/**/*.{ts,json}\" \"apps/cms/**/*.{js,ts,tsx,json,mjs,css,scss}\" \"apps/interactive-map/**/*.{js,json}\" \"tools/**/*.{ts,js,json,md}\" \"*.{json,ts,js,mjs,yml,yaml,md}\" \".github/workflows/*.{yml,yaml}\"",
    "format:check": "prettier --check README.md CONTRIBUTING.md AGENTS.md \"docs/plan/*.md\" \"apps/README.md\" \"data/README.md\" \"docs/README.md\" \"docs/product/README.md\" \"packages/**/*.{ts,json}\" \"apps/server/**/*.{ts,json}\" \"apps/cms/**/*.{js,ts,tsx,json,mjs,css,scss}\" \"apps/interactive-map/**/*.{js,json}\" \"tools/**/*.{ts,js,json,md}\" \"*.{json,ts,js,mjs,yml,yaml,md}\" \".github/workflows/*.{yml,yaml}\"",
    "test": "vitest run",
    "test:coverage:rules-core": "vitest run packages/rules-core/src --coverage",
    "test:unit": "vitest run packages",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "validate": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm validate:geojson && pnpm build:map && pnpm devlab:test",
    "db:generate": "pnpm --filter @knightandwizard/server db:generate",
    "db:migrate": "pnpm --filter @knightandwizard/server db:migrate",
    "db:reset": "pnpm --filter @knightandwizard/server db:reset",
    "dev:server": "pnpm --filter @knightandwizard/server dev",
    "devlab:reset": "bash scripts/devlab-reset.sh",
    "db:seed": "pnpm --filter @knightandwizard/server db:seed",
    "knowledge:dry-run": "pnpm --filter @knightandwizard/server knowledge:dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/env": "16.2.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "payload": "3.84.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/decarvalhoe/knightandwizard.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "knight-and-wizard",
    "rpg",
    "tabletop",
    "digital-adaptation",
    "fantasy",
    "monorepo"
  ]
}
